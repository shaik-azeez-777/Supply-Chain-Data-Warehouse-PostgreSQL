CREATE OR REPLACE VIEW gold.v_inventory_analysis AS
SELECT 
    p.sku, 
    l.location_name, 
    f.stock_levels,
    CASE 
        WHEN f.stock_levels < 20 THEN 'Low Stock' 
        WHEN f.stock_levels > 80 THEN 'High Stock' 
        ELSE 'Healthy' 
    END AS stock_status
FROM silver.fct_supply_chain f
JOIN silver.dim_products p ON f.product_key = p.product_key
JOIN silver.dim_locations l ON f.location_key = l.location_key;

SELECT * FROM gold.v_inventory_analysis LIMIT 10;
